; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the code is considered standalone and can be edited manually.

config_version=5

[application]

config/name="Yorlords"
config/description="A turn-based fantasy strategy game in the spirit of Warlords II. Conquer cities, build armies, and battle for dominion across a fantasy world."
config/version="1.0.0"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/image=""
boot_splash/bg_color=Color(0.1, 0.05, 0.2, 1)
config/icon="res://assets/icon.svg"

[autoload]

GameManager="*res://autoloads/GameManager.gd"
NetworkManager="*res://autoloads/NetworkManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[input]

ui_accept={
"deadzone": 0.5,
